#!/usr/bin/env bash
# Pre-commit hook: lint-staged (parallel phase 1), typecheck + test (sequential phase 2)
set -euo pipefail

# --- Config-only fast path ---
# If only config/docs files changed, skip expensive checks
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)
if echo "$STAGED_FILES" | grep -qvE '^\.(claude|github)/|\.md$|\.json$|\.ya?ml$|\.toml$'; then
  : # Non-config files present — run full checks
else
  echo "[pre-commit] Config/docs only — skipping lint and tests"
  exit 0
fi

# --- Phase 1: Parallel ---
echo "[pre-commit] Phase 1: lint-staged"
if command -v npx &>/dev/null && [ -f "package.json" ]; then
  npx lint-staged --concurrent false 2>/dev/null || {
    echo "[pre-commit] lint-staged failed"
    exit 1
  }
fi

# --- Phase 2: Sequential ---
echo "[pre-commit] Phase 2: typecheck + test"

# Typecheck
if command -v npx &>/dev/null; then
  if npx --no-install tsc --version &>/dev/null 2>&1; then
    echo "[pre-commit] Running typecheck..."
    npx tsc --noEmit || {
      echo "[pre-commit] Typecheck failed"
      exit 1
    }
  fi
fi

# Tests (only related to staged files)
if command -v npx &>/dev/null; then
  if npx --no-install vitest --version &>/dev/null 2>&1; then
    echo "[pre-commit] Running related tests..."
    npx vitest related --run -- $STAGED_FILES 2>/dev/null || {
      echo "[pre-commit] Tests failed"
      exit 1
    }
  elif npx --no-install jest --version &>/dev/null 2>&1; then
    echo "[pre-commit] Running related tests..."
    npx jest --bail --findRelatedTests -- $STAGED_FILES 2>/dev/null || {
      echo "[pre-commit] Tests failed"
      exit 1
    }
  fi
fi

echo "[pre-commit] All checks passed"
