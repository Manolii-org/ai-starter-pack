# pack-components.yml — component pins + instance contract (machine-emitted).
# Generated by the AI Starter Pack Copier template; regenerated on `copier update`.
# Edit instance values via `copier update` answers, not by hand.
# Schema: ADR-0023 Decision 4; required_secrets: report §9-R1 / §10 row 16.
schema_version: 1

components:
  claude_framework:
    channel: copier            # future: plugin marketplace (ADR-0023 Decision 3)
    version: "1.2.0"
  ci_pipeline:
    channel: copier            # future: reusable-workflow tag (gated on Decision 2 repo)
    version: "1.2.0"
  litellm_proxy:
    channel: fly-config        # pinned public image + injected config (no custom image)
    litellm_version: "v1.82.3-stable.patch.4"
    enabled: {{ oss_routing | lower }}

instance:
  name: "{{ instance_name }}"
  doppler_project: "{{ doppler_project }}"
  doppler_config: "{{ doppler_config }}"
  fly_app: "{{ fly_app }}"
  repo_vars:
{% if oss_routing %}
    - LITELLM_PROXY_URL
{% endif %}
{% if mesh_telemetry %}
    - MESH_INVOCATION_URL
{% endif %}
{% if not oss_routing and not mesh_telemetry %}
    []
{% endif %}

  # Secrets this instance must have in place before its CI / proxy / telemetry
  # work. scripts/first-run-setup.py --verify-secrets checks the doppler.keys
  # section against the local environment and fails loudly on gaps; github and
  # fly sections are printed as a manual checklist (not locally verifiable).
  required_secrets:
    github:
      - ANTHROPIC_API_KEY
{% if oss_routing %}
      - DOPPLER_SERVICE_TOKEN_LITELLM
      - FLY_API_TOKEN
      - LITELLM_MASTER_KEY
{% endif %}
    doppler:
      project: "{{ doppler_project }}"
      keys:
{% if oss_routing %}
        - LITELLM_MASTER_KEY
{% endif %}
{% if kl_integration %}
        - MCP_API_KEY
{% endif %}
{% if browserbase %}
        - BROWSERBASE_API_KEY
        - BROWSERBASE_PROJECT_ID
{% endif %}
{% if langfuse_telemetry %}
        - LANGFUSE_PUBLIC_KEY
        - LANGFUSE_SECRET_KEY
{% endif %}
{% if codex_adversarial %}
        - OPENAI_API_KEY
{% endif %}
{% if mesh_telemetry %}
        - MESH_BEARER_AGENT
{% endif %}
{% if not oss_routing and not kl_integration and not browserbase and not langfuse_telemetry and not codex_adversarial and not mesh_telemetry %}
        []
{% endif %}
    fly:
{% if oss_routing %}
      - LITELLM_MASTER_KEY
{% endif %}
{% if not oss_routing %}
      []
{% endif %}
