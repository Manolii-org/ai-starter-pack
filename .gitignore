# Runtime files generated by the AI Starter Pack hooks — do not commit
.ai/spend-cache/
.ai/fetch/
.ai/system-health.json
.ai/system-health.md
.ai/sessions/
.ai/*.jsonl
.ai/session-context.md
.ai/compact-state.json
.git/.credential-cache/
.git/.session-health

# Python caches (test / runtime)
__pycache__/
*.pyc

# Track these (persistent memory and decisions)
!.ai/memory/
!.ai/decisions/
!.ai/knowledge-index.md
!.ai/skill-graph.md
!.ai/setup-complete
!.ai/guards.json

# OS / editor noise
.DS_Store
*.swp
*.swo

# Rendered output (re-generate with render-pack.py)
dist/

# Session retrospective runtime (Stop hook) — do not commit
.ai/memory/retrospectives/.last-capture-failed
.ai/memory/retrospectives/*.json
!.ai/memory/retrospectives/.gitkeep
!.ai/memory/retrospectives/session-retrospectives.jsonl
.ai/memory/retrospectives/.last-capture-mtime
# Advisory lock file created by _retro_lock() — persists after fcntl
# release and would otherwise dirty the worktree on every Stop capture.
# Codex P1 2026-07-19.
.ai/memory/retrospectives/.retrospectives.lock


.ai/retrospective-staging/

!.claude/memory

.ai/recent-navigation-warning.md

# WS3 pack: runtime archive of migration conflicts (see
# scripts/migrate-memory-path.sh). Contents are per-run mktemp dirs
# holding legacy memory records; they must not enter git history.
# Keep the parent .gitkeep tracked if present.
.ai/memory/archive/migration-conflicts/*
!.ai/memory/archive/migration-conflicts/.gitkeep

# WS3 pack: local memory runtime stores. Scaffolds are tracked via
# .gitkeep only — the jsonl files fill with per-session telemetry
# (fact assertions, learned patterns, session summaries) that must
# not enter git history. Codex P2 2026-07-19.
.ai/memory/facts.jsonl
.ai/memory/patterns.jsonl
.ai/memory/sessions.jsonl
