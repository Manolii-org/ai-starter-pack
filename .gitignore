# Runtime files generated by the AI Starter Pack hooks — do not commit
.ai/spend-cache/
.ai/fetch/
.ai/system-health.json
.ai/system-health.md
.ai/sessions/
.ai/*.jsonl
.ai/session-context.md
.ai/compact-state.json
.git/.credential-cache/
.git/.session-health

# Python caches (test / runtime)
__pycache__/
*.pyc

# Track these (persistent memory and decisions)
!.ai/memory/
!.ai/decisions/
!.ai/knowledge-index.md
!.ai/skill-graph.md
!.ai/setup-complete
!.ai/guards.json

# OS / editor noise
.DS_Store
*.swp
*.swo

# Rendered output (re-generate with render-pack.py)
dist/

# Session retrospective runtime (Stop hook) — do not commit
.ai/memory/retrospectives/.last-capture-failed
.ai/memory/retrospectives/*.json
!.ai/memory/retrospectives/.gitkeep
!.ai/memory/retrospectives/session-retrospectives.jsonl
